@inject IJSRuntime JS

<nav id="navbar" class="fixed w-full z-50 top-0 transition-all duration-300 bg-soft-gray/90 dark:bg-navy/90 backdrop-blur-md">
    <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
        <div class="font-heading text-xl font-semibold tracking-tight">
            AS<span class="text-blue">.</span>
        </div>
        <div class="hidden md:flex space-x-8 text-sm font-medium">
            <a href="#experience" class="hover:text-blue dark:hover:text-teal transition-colors">Experience</a>
            <a href="#projects" class="hover:text-blue dark:hover:text-teal transition-colors">Projects</a>
            <a href="#skills" class="hover:text-blue dark:hover:text-teal transition-colors">Skills</a>
            <a href="#education" class="hover:text-blue dark:hover:text-teal transition-colors">Education</a>
            <a href="#certifications" class="hover:text-blue dark:hover:text-teal transition-colors">Certifications</a>
            <a href="#trainings" class="hover:text-blue dark:hover:text-teal transition-colors">Trainings</a>
            <a href="#publications" class="hover:text-blue dark:hover:text-teal transition-colors">Publications</a>
        </div>
        <button @onclick="ToggleTheme" class="p-2 rounded-full hover:bg-slate-200 dark:hover:bg-slate-800 transition-colors" aria-label="Toggle Dark Mode">
            @if (_isDarkMode)
            {
                <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
                </svg>
            }
            else
            {
                <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
                </svg>
            }
        </button>
    </div>
</nav>

@code {
    private bool _isDarkMode;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isDarkMode = await JS.InvokeAsync<bool>("siteInterop.initTheme");
            await JS.InvokeVoidAsync("siteInterop.initNavbarScroll");
            await JS.InvokeVoidAsync("siteInterop.initSmoothScroll");
            StateHasChanged();
        }
    }

    private async Task ToggleTheme()
    {
        _isDarkMode = await JS.InvokeAsync<bool>("siteInterop.toggleTheme");
    }
}
